---
layout: layout.njk
---

<div class="post-frame">
    <head><link rel="stylesheet" href="/_css/post.css"></head>
    <div class="post-info">
        <h1 class="post-title">{{ title }}</h1>
        <p>{{ description }}</p>
        <p class="post-date">投稿日 : {{ date.toLocaleDateString() }}</p>
    </div>
    <div class="post">
        {{ content | safe }}
    </div>
</div>