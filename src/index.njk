<section class="sub-frame" id="blog-preview">
    <h2 class="section-title">Blog</h2>
    <div class="blog-preview-list">
        {%- for post in collections.post | reverse -%}
        {%- if loop.index <= 3 -%}
        <div class="preview-card">
            <a href="{{ post.url }}" class="card-link"></a>
            <p class="preview-title">{{ post.data.title }}</p>
            <p class="preview-description">{{ post.data.description }}</p>
            <p class="preview-meta">{{ post.date.toLocaleDateString() }} &nbsp;·&nbsp; {{ (post.templateContent | wordCount / 400) | round }} 分程度で読めます ({{ post.templateContent | wordCount }} 字)</p>
        </div>
        {%- endif -%}
        {%- endfor -%}
    </div>
    <p class="blog-more"><a href="/blog/">すべての記事を見る →</a></p>
</section>

<div id="toast" class="toast">Discord IDをコピーしました！</div>
<script>
    document.getElementById('discord_id').addEventListener('click', () => {
        const DISCORD_ID = 'neko64v';
        navigator.clipboard.writeText(DISCORD_ID).then(() => {
            const toast = document.getElementById('toast');
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2000);
        });
    });
</script>